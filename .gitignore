#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.pyw
.hypothesis/
.pytest_cache/
cover/

# Jupyter Notebook
.ipynb_checkpoints

# Environments
.env
.venv
env/
venv/
ENV/
env.bak/
venv.bak/

# macOS
.DS_Store

# IDEs
.vscode/
.idea/
*.swp

# Project specific
# NOTE: paths are anchored with a leading slash so that ONLY the top-level
# data/ output dir is ignored — the src/data/ source package stays tracked.
/scratch/
/checkpoints/
/checkpoints_*/
/data/
/logs/
/logs_*/
/exported_model_hf/
*.pt
*.bin
*.safetensors
